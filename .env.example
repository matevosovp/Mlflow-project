# PostgreSQL backend and model registry
DB_DESTINATION_HOST=replace-me
DB_DESTINATION_PORT=5432
DB_DESTINATION_NAME=replace-me
DB_DESTINATION_USER=replace-me
DB_DESTINATION_PASSWORD=replace-me

# S3-compatible artifact storage
MLFLOW_S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BUCKET_NAME=replace-me
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
BASELINE_MODEL_S3_URI=s3://replace-me/models/real_estate/model.pkl

# MLflow
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_HOST=127.0.0.1
MLFLOW_PORT=5000
MLFLOW_EXPERIMENT_NAME=model_improvement_matevosov
