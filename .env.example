# PostgreSQL data source, MLflow backend and Model Registry
DB_DESTINATION_HOST=replace-me
DB_DESTINATION_PORT=5432
DB_DESTINATION_NAME=replace-me
DB_DESTINATION_USER=replace-me
DB_DESTINATION_PASSWORD=replace-me
DATA_TABLE_NAME=public.real_estate_dataset_clean
TARGET_COLUMN=price

# S3-compatible artifact storage. AWS credentials may be omitted when an IAM
# role or another boto3 credential provider is available.
MLFLOW_S3_ENDPOINT_URL=https://storage.yandexcloud.net
S3_BUCKET_NAME=replace-me
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
BASELINE_MODEL_S3_URI=s3://replace-me/models/real_estate/model.joblib
BASELINE_MODEL_SHA256=replace-with-the-trusted-64-character-sha256
BASELINE_DROP_COLUMNS=flat_id,building_id,studio

# MLflow
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_HOST=127.0.0.1
MLFLOW_PORT=5000
MLFLOW_EXPERIMENT_NAME=model_improvement_matevosov
MLFLOW_REGISTERED_MODEL_NAME=real_estate_price_model

# Deterministic training policy: 60% train, 20% validation, 20% final test
RANDOM_STATE=42
VALIDATION_SIZE=0.2
TEST_SIZE=0.2
SPLIT_GROUP_COLUMN=building_id
BUILD_YEAR_REFERENCE=2026
OPTUNA_TRIALS=10
RANDOM_SEARCH_ITERATIONS=10
